{
    "providers": [
        {
            "type": "remote",
            "tag": "ZQ",
            "health_check": {
                "enabled": false,
                "url": "https://www.gstatic.com/generate_204",
                "interval": "10m",
                "timeout": "5s"
            },
            // 订阅链接 务必使用 Clash/Mihomo 格式
            "url": "https://dash.pqjc.site/api/v1/client/subscribe?token=2927a313392c80bcc33f5263978b4064",
            "exclude": "Traffic|Expire",
            "update_interval": "24h",
            "override_dialer": {}
        },
        {
            "type": "remote",
            "tag": "LXY",
            "health_check": {
                "enabled": false,
                "url": "https://www.gstatic.com/generate_204",
                "interval": "10m",
                "timeout": "5s"
            },
            // 订阅链接 务必使用 Clash/Mihomo 格式
            "url": "https://liangxin.xyz/api/v1/liangxin?OwO=b9d7616efa898e337842969b17e7e6e7",
            "update_interval": "24h",
            "override_dialer": {}
        },
        {
            "type": "remote",
            "tag": "BigME",
            "health_check": {
                "enabled": false,
                "url": "https://www.gstatic.com/generate_204",
                "interval": "10m",
                "timeout": "5s"
            },
            // 订阅链接 务必使用 Clash/Mihomo 格式
            "url": "https://moes.lnaspiring.com/Moe233-Subs/qwbm/api/v1/client/subscribe?token=2d85c5bb05dbab1fef2438dc3e52495d",
            "update_interval": "24h",
            "override_dialer": {}
        }
    ],
    "log": {
        "disabled": false,
        "level": "debug",
        "output": "/tmp/sing-box.log",
        "timestamp": true
    },
    "experimental": {
        "clash_api": {
            //如果你的软路由局域网IP为 192.168.50.1, 那么启动sing-box后的 dashboard 访问地址即为 http://192.168.50.1:3000 （下面的 0.0.0.0 *无需画蛇添足*去改变！）
            "external_controller": "0.0.0.0:3000",
            // dashboard web-UI 保存路径（若无，建议提前 mkdir 创建）
            "external_ui": "/etc/momo/run/ui",
            "external_ui_download_url": "https://gh-proxy.com/https://github.com/Zephyruso/zashboard/archive/refs/heads/gh-pages.zip",
            "external_ui_update_interval": "1d",
            "external_ui_download_detour": "🎯 全球直连",
            "secret": "",
            "default_mode": "rule"
        },
        "cache_file": {
            "enabled": true,
            "path": "/etc/momo/run/cache.db",
            "store_fakeip": false,
            "rdrc_timeout": "7d"
        }
    },
    "inbounds": [
        // 下列借鉴 https://github.com/qichiyuhub/rule/blob/main/config/singbox/1.12.x/momo.json
        // 其逻辑是：把redir、tproxy、tun都一网打尽地放入json配置文件，以便通过openwrt-momo进行随意切换
        // 注意：对于openwrt-momo插件，下列tag名称（如redirect-in、tproxy-in、tun-in）受到该插件的严格限定，切勿自作主张进行重命名。否则，momo插件找不到相应tag就会报错！
        {
            "tag": "dns-in",
            "type": "direct",
            "listen": "::",
            "listen_port": 1053
        },
        {
            "tag": "http-in",
            "type": "http",
            "listen": "::",
            "listen_port": 8080
        },
        {
            "tag": "socks-in",
            "type": "socks",
            "listen": "::",
            "listen_port": 1080
        },
        {
            "tag": "redirect-in",
            "type": "redirect",
            "listen": "::",
            "listen_port": 7890
        },
        {
            "tag": "tproxy-in",
            "type": "tproxy",
            "listen": "::",
            "listen_port": 7891
        },
        {
            "tag": "tun-in",
            "type": "tun",
            "interface_name": "momo",
            "address": [
                "172.18.0.1/30"
            ],
            "mtu": 9000,
            "auto_route": true,
            "route_exclude_address_set": ["cn-ip"],
            "route_exclude_address": [
                "10.0.0.0/8",
                "100.64.0.0/10",
                "169.254.0.0/16",
                "172.16.0.0/12",
                "192.0.0.0/24",
                "192.168.0.0/16"
            ],
            "strict_route": false,
            "endpoint_independent_nat": false,
            "stack": "mixed",
            //在开启 "auto_redirect": true 之前，务必*再三确认*软路由是 Linux 或 OpenWrt，且采用*firewall4 (nftables)*防火墙!!
            "auto_redirect": true
        }
    ],
    "outbounds": [
        { "tag": "🚀 节点选择", "type": "selector", "outbounds": [ "🇭🇰 香港♻️", "🇹🇼 台湾♻️", "🇯🇵 日本♻️", "🇸🇬 新加坡♻️", "🇰🇷 韩国♻️", "🇺🇸 美国♻️", "🇪🇺 欧洲♻️", "🇭🇰 香港 手动", "🇹🇼 台湾 手动", "🇯🇵 日本 手动", "🇸🇬 新加坡 手动", "🇺🇸 美国 手动", "🇪🇺 欧洲 手动", "👆 手动-主", "❤️‍🩹 低倍率♻️", "❤️‍🩹 低倍率 手动" ], "default": "👆 手动-主" },
        { "tag": "👆 手动-主", "type": "selector", "use_all_providers": true },
        { "tag": "👆🏾 手动-副", "type": "selector", "use_all_providers": true },
        { "tag": "🐟 漏网之鱼", "type": "selector", "outbounds": [ "❤️‍🩹 低倍率♻️", "❤️‍🩹 低倍率 手动", "👆 手动-主", "👆🏾 手动-副", "🚀 节点选择", "🎯 全球直连" ] },
        //或许有人觉得这里没有按HK、TW等顺序做“工整对仗”。此处的考虑是：OAI、Claude的算力服务器在美国东北部，所以通过沪日/京欧专线去美东是首选。但在无沪日、无京欧专线时，优质的新加坡节点也算是次优选（除了有点绕）
        { "tag": "🤖 OpenAI", "type": "selector", "outbounds": [ "🇯🇵 日本 手动", "🇺🇸 美国 手动", "🇪🇺 欧洲 手动", "🇯🇵 日本♻️", "🇺🇸 美国♻️", "🇪🇺 欧洲♻️", "🇸🇬 新加坡♻️" ] },
        { "tag": "🤖 Claude", "type": "selector", "outbounds": [ "🇯🇵 日本 手动", "🇺🇸 美国 手动", "🇪🇺 欧洲 手动", "🇯🇵 日本♻️", "🇺🇸 美国♻️", "🇪🇺 欧洲♻️", "🇸🇬 新加坡♻️", "🤖 OpenAI" ], "default": "🤖 OpenAI" },
        { "tag": "🤖 Copilot", "type": "selector", "outbounds": [ "🇭🇰 香港♻️", "🇯🇵 日本♻️", "🇸🇬 新加坡♻️", "🇹🇼 台湾♻️", "🇺🇸 美国♻️", "🇪🇺 欧洲♻️" ] },
        { "tag": "🤖 POE", "type": "selector", "outbounds": [ "🤖 Copilot", "🤖 OpenAI", "🇭🇰 香港♻️", "🇯🇵 日本♻️", "🇸🇬 新加坡♻️" ], "default": "🤖 OpenAI" },

        { "tag": "🔍 Google", "type": "selector", "outbounds": [ "🇭🇰 香港♻️", "🇹🇼 台湾♻️", "🇯🇵 日本♻️", "🇸🇬 新加坡♻️", "🇺🇸 美国♻️", "🇪🇺 欧洲♻️", "🇭🇰 香港 手动", "🇹🇼 台湾 手动", "🇯🇵 日本 手动", "🇸🇬 新加坡 手动", "🇺🇸 美国 手动", "🎯 全球直连", "🚀 节点选择" ], "default": "🇹🇼 台湾♻️" },
        { "tag": "📹 YouTube", "type": "selector", "outbounds": [ "❤️‍🩹 低倍率♻️", "❤️‍🩹 低倍率 手动", "🚀 节点选择", "👆 手动-主", "👆🏾 手动-副", "🎯 全球直连", "🇭🇰 香港♻️", "🇹🇼 台湾♻️", "🇯🇵 日本♻️", "🇸🇬 新加坡♻️", "🇺🇸 美国♻️"], "default": "❤️‍🩹 低倍率 手动" },
        { "tag": "📢 谷歌FCM", "type": "selector", "outbounds": [ "🎯 全球直连", "🔍 Google" ] },

        { "tag": "🌍 国外流媒体", "type": "selector", "outbounds": [ "🎯 全球直连", "❤️‍🩹 低倍率 手动", "❤️‍🩹 低倍率♻️", "🚀 节点选择", "👆 手动-主", "👆🏾 手动-副"]},
        { "tag": "✖️ 推特IG", "type": "selector", "outbounds": [ "📹 YouTube", "👆 手动-主", "👆🏾 手动-副", "❤️‍🩹 低倍率 手动", "🇭🇰 香港 手动", "🇹🇼 台湾 手动", "🇯🇵 日本 手动", "🇸🇬 新加坡 手动", "🇭🇰 香港♻️", "🇹🇼 台湾♻️", "🇯🇵 日本♻️", "🇸🇬 新加坡♻️", "🇺🇸 美国♻️", "🇪🇺 欧洲♻️", "🎯 全球直连", "🚀 节点选择" ] },
        { "tag": "📲 Telegram", "type": "selector", "outbounds": ["❤️‍🩹 低倍率 手动", "🇸🇬 新加坡 手动", "🇪🇺 欧洲 手动", "🇺🇸 美国 手动", "👆 手动-主", "👆🏾 手动-副" ], "default": "🇸🇬 新加坡 手动"},
        { "tag": "🎼 Spotify", "type": "selector", "outbounds": [ "📹 YouTube", "🚀 节点选择", "🎯 全球直连", "🇭🇰 香港♻️", "🇹🇼 台湾♻️", "🇯🇵 日本♻️", "🇸🇬 新加坡♻️","🇺🇸 美国♻️"] },
        { "tag": "🎵 TikTok", "type": "selector", "outbounds": [ "📹 YouTube", "🚀 节点选择", "🎯 全球直连", "🇹🇼 台湾♻️", "🇯🇵 日本♻️", "🇸🇬 新加坡♻️","🇺🇸 美国♻️"], "default": "🎯 全球直连" },
        { "tag": "🌪 Github", "type": "selector", "outbounds": [ "❤️‍🩹 低倍率 手动", "👆 手动-主", "👆🏾 手动-副", "🎯 全球直连", "🚀 节点选择" ], "default": "👆🏾 手动-副" },

        { "tag": "💵 北美站", "type": "selector", "outbounds": [ "🇺🇸 美国♻️", "🇺🇸 美国 手动", "👆🏾 手动-副", "🇯🇵 日本♻️", "🇭🇰 香港♻️", "🇸🇬 新加坡♻️", "🚀 节点选择" ] },
        { "tag": "💶 欧洲站", "type": "selector", "outbounds": [ "🇪🇺 欧洲♻️", "🇪🇺 欧洲 手动", "👆🏾 手动-副", "🇭🇰 香港♻️", "🇸🇬 新加坡♻️", "🎯 全球直连", "🚀 节点选择" ] },

        { "tag": "🎮 游戏服务", "type": "selector", "outbounds": [ "🎯 全球直连", "❤️‍🩹 低倍率♻️", "🚀 节点选择", "👆 手动-主" ] },
        { "tag": "🪟 微软服务", "type": "selector", "outbounds": [ "🎯 全球直连", "🚀 节点选择" ], "default": "🎯 全球直连" },
        { "tag": "🪟 OneDrive", "type": "selector", "outbounds": [ "🎯 全球直连", "🚀 节点选择" ], "default": "🎯 全球直连" },
        { "tag": "🍎 苹果服务", "type": "selector", "outbounds": [ "🎯 全球直连", "🚀 节点选择" ], "default": "🎯 全球直连" },
        { "tag": "📺 Bilibili", "type": "selector", "outbounds": ["🎯 全球直连", "🚀 节点选择"], "default": "🎯 全球直连"},

        { "tag": "📈 网络测试", "type": "selector", "use_all_providers": true, "outbounds": [ "🎯 全球直连" ], "default": "🎯 全球直连" },
        { "tag": "🪜 代理域名", "type": "selector", "outbounds": [ "🚀 节点选择", "🎯 全球直连" ] },


        { "tag": "🇭🇰 香港♻️", "type": "urltest", "tolerance": 50, "use_all_providers": true, "include": "ZQ.*AWS香港|LXY.*香港高速|BigME.*HK.*稳定"},

        { "tag": "🇹🇼 台湾♻️", "type": "urltest", "tolerance": 50, "use_all_providers": true, "include": "ZQ.*台湾|LXY.*台湾高速|BigME.*TW.*稳定"},

        { "tag": "🇯🇵 日本♻️", "type": "urltest", "tolerance": 50, "use_all_providers": true, "include": "ZQ.*日本东京|LXY.*日本高速|BigME.*JP.*稳定"},

        { "tag": "🇸🇬 新加坡♻️", "type": "urltest", "tolerance": 50, "use_all_providers": true, "include": "ZQ.*新加坡|LXY.*新加坡高速|BigME.*SG.*稳定", "exclude": "hy2"},

        { "tag": "🇰🇷 韩国♻️", "type": "urltest", "tolerance": 50, "use_all_providers": true, "include": "ZQ.*韩国首尔|LXY.*韩国高速"},

        { "tag": "🇺🇸 美国♻️", "type": "urltest", "tolerance": 50, "use_all_providers": true, "include": "THIS_IS_A_PLACEHOLDER_AND_WILL_NOT_MATCH_ANYTHING"},

        //以下一行的 urltest 欧洲♻️仅囊括 "FC"订阅里的节点——这是操作节点组的一个例子。完全可以把：
        // "providers": [ "FC" ]   ➡️替换成➡️   "use_all_providers": true
        { "tag": "🇪🇺 欧洲♻️", "type": "urltest", "tolerance": 50, "providers": [ "FC" ], "include": "🇬🇧|🇩🇪|🇳🇱|🇫🇷|🇸🇪|🇨🇭|🇮🇪" },

        { "tag": "❤️‍🩹 低倍率♻️", "type": "urltest", "tolerance": 150, "use_all_providers": true, "include": "0\\.\\d+\\s?(倍|x|X|×)|实验|日用" },

        { "tag": "REJECT", "type": "block" },
        { "tag": "🛑 广告拦截", "type": "selector", "outbounds": [ "REJECT" ] },
        { "tag": "🎯 全球直连", "type": "direct" }
    ],
    "route": {
        "default_domain_resolver": "Local-DNS",
        "rules": [
            {"action": "sniff"},
            {"inbound": "dns-in", "action": "hijack-dns"},

            //【可选】当singbox挂在 旁路 时，如下一行可以删去
            {"action": "route", "source_ip_cidr": ["192.168.6.1/32", "192.168.6.252/32", "192.168.6.251/32", "172.18.0.1/24"], "outbound": "🎯 全球直连"},
            //【可选】在 Linux 下面使用TUN模式时，可以让icmp走直连——但如果使用redirect或tproxy模式，如下一行也可以删去
            {"protocol": "icmp", "outbound": "🎯 全球直连"},
            {"ip_is_private": true, "outbound": "🎯 全球直连"},
            //【可选】以下为零散写入 route 分流规则的例子1: 将frpc➕miaospeed测速后端➕tailscale穿透➕zerotier穿透 ➡️ 直连
            {"action": "route", "process_name": ["frpc", "miaospeed", "miaospeed-linux-arm64", "tailscale", "tailscaled", "zerotier"], "outbound": "🎯 全球直连"},
            //【可选】以下为零散写入 route 分流规则的例子2: 将 epicgames 的某二级域名 ➡️ 直连
            {"action" :"route", "domain_suffix": "cloudflare.epicgamescdn.com", "outbound": "🎯 全球直连"},
            //【可选】以下为零散写入 route 分流规则的例子3: 将 Le Chat （法国的AI） ➡️ 💶欧洲节点 —— 如果需要大面积分流一些域名，建议转而借助 *.srs或.json格式的"ruls_set"规则集* 来调用！
            {"action" :"route", "domain_suffix": ["mistral.ai", "intercom.io", "intercomcdn.com"], "outbound": "💶 欧洲站"},

            //【可选】以下为零散写入 route 分流规则的例子4: 将 Telegram 的 DC1➕DC3 ➡️ 💵北美节点
            {"action" :"route", "ip_cidr": ["91.108.12.0/22", "149.154.172.0/22", "2001:b28:f23d::/48"], "outbound": "💵 北美站"},
            //【可选】以下为零散写入 route 分流规则的例子4: 将 Telegram 的 DC2➕DC4 ➡️ 💶欧洲节点
            {"action" :"route", "ip_cidr": ["5.28.192.0/18", "91.105.192.0/23", "91.108.4.0/22", "91.108.8.0/22", "95.161.64.0/20", "109.239.140.0/24", "149.154.160.0/21", "185.76.151.0/24", "2001:67c:4e8::/48", "2a0a:f280:203::/48"], "outbound": "💶 欧洲站"},

            {"action": "route", "rule_set": [ "ads", "pcdn" ], "outbound": "🛑 广告拦截" },
            {"action": "route", "clash_mode":"direct", "outbound":"🎯 全球直连"},
            {"action": "route", "clash_mode":"global", "outbound":"GLOBAL"},

            {"action": "route", "rule_set": [ "private", "privateip", "applications" ], "outbound": "🎯 全球直连" },

            {"action": "route", "rule_set": [ "twitter", "instagram", "facebook", "whatsapp" ], "outbound": "✖️ 推特IG" },
            {"action": "route", "rule_set": [ "games-cn", "steam", "epicgames", "playstation" ], "outbound": "🎮 游戏服务" },
            {"action": "route", "rule_set": [ "openai" ], "outbound": "🤖 OpenAI" },
            {"action": "route", "rule_set": [ "claude" ], "outbound": "🤖 Claude" },
            {"action": "route", "rule_set": [ "poe", "perplexity" ], "outbound": "🤖 POE" },
            {"action": "route", "rule_set": [ "copilot" ], "outbound": "🤖 Copilot" },

            {"action": "route", "rule_set": [ "googlefcm" ], "outbound": "📢 谷歌FCM" },
            {"action": "route", "rule_set": [ "youtube", "googledrive" ], "outbound": "📹 YouTube" },
            {"action": "route", "rule_set": [ "google" ], "outbound": "🔍 Google" },

            {"action": "route", "rule_set": [ "netflix", "disney", "appletv", "primevideo", "hbomax" ], "outbound": "🌍 国外流媒体" },
            {"action": "route", "rule_set": [ "tiktok" ], "outbound": "🎵 TikTok" },
            {"action": "route", "rule_set": [ "spotify" ], "outbound": "🎼 Spotify" },
            {"action": "route", "rule_set": [ "gitlab", "github", "docker", "homebrew" ], "outbound": "🌪 Github" },

            //【注意，这是本地规则集"NorthAmerican-J"的演示。在dns.rules、route.rules、route.rule_set分别出现一次。这三串，可以一并替换/一并删除】
            {"action": "route", "rule_set": [ "NorthAmerican-J" ], "outbound": "💵 北美站" },

            {"action": "route", "rule_set": [ "microsoft-cn" ], "outbound": "🪟 微软服务" },
            {"action": "route", "rule_set": [ "onedrive" ], "outbound": "🪟 OneDrive" },
            {"action": "route", "rule_set": [ "apple", "apple-cn" ], "outbound": "🍎 苹果服务" },

            {"action": "route", "rule_set": [ "bilibili" ], "outbound": "📺 Bilibili" },
            {"action": "route", "rule_set": [ "networktest" ], "outbound": "📈 网络测试" },
            {"action": "route", "rule_set": [ "telegram", "telegram-ip" ], "outbound": "📲 Telegram" },

            {"action": "route", "rule_set": [ "cn-domain", "cn-ip" ], "outbound": "🎯 全球直连" },
            {"action": "route", "rule_set": [ "proxy" ], "outbound": "🪜 代理域名" }
